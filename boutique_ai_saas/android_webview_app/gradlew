#!/usr/bin/env sh
##############################################################################
#
#   Correct Gradle Wrapper Script
#
##############################################################################

DIR="$( cd "$( dirname "$0" )" && pwd )"
CLASSPATH="$DIR/gradle/wrapper/gradle-wrapper.jar"

# If JAVA_HOME exists, use it
if [ -n "$JAVA_HOME" ] ; then
    JAVA_CMD="$JAVA_HOME/bin/java"
else
    JAVA_CMD="java"
fi

exec "$JAVA_CMD" -jar "$CLASSPATH" "$@"
