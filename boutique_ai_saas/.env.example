# Django
DJANGO_DEBUG=1
DJANGO_SECRET_KEY=change-me
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
# For HTTPS domains in production, e.g. https://yourusername.pythonanywhere.com
DJANGO_CSRF_TRUSTED_ORIGINS=
# Main domain used for optional vendor subdomains (<vendor>.<MAIN_DOMAIN>)
MAIN_DOMAIN=localhost
# In production (DJANGO_DEBUG=0) you typically want HTTPS redirect
DJANGO_SECURE_SSL_REDIRECT=1

# HuggingFace Inference API (free tier limits apply)
HF_API_TOKEN=
HF_RMBG_MODEL=facebook/mask2former-swin-large-coco-panoptic
# Optional: set your own try-on model endpoint ID
HF_TRYON_MODEL=

# Replicate (free tier limits apply)
REPLICATE_API_TOKEN=
REPLICATE_TRYON_VERSION=

# Deploy webhook (optional; for GitHub -> PythonAnywhere pull)
DEPLOY_HOOK_SECRET=change-me

# WhatsApp dummy webhook (optional)
WHATSAPP_WEBHOOK_SECRET=change-me

# Vendor payment settings (optional defaults)
DEFAULT_UPI_ID=

# Wallet
WALLET_CASHBACK_RATE=0.02
WALLET_REFERRAL_BONUS=25.00
